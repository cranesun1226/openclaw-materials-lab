{
  "name": "@cranesun/openclaw-materials-lab",
  "version": "0.1.0",
  "description": "Native OpenClaw plugin for autonomous materials-science research workflows.",
  "license": "MIT",
  "author": "Crane Sun",
  "homepage": "https://github.com/cranesun1226/openclaw-materials-lab#readme",
  "bugs": {
    "url": "https://github.com/cranesun1226/openclaw-materials-lab/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cranesun1226/openclaw-materials-lab.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "skills",
    "python/materials_lab/*.py",
    "python/requirements.txt",
    "python/pyproject.toml",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "materials-science",
    "materials-project",
    "pymatgen",
    "ase"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.3.24-beta.2"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.41"
  },
  "devDependencies": {
    "@types/node": "^24.2.1",
    "openclaw": "2026.4.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "smoke": "vitest run tests/plugin.smoke.test.ts",
    "pack:verify": "npm pack --dry-run --cache ./.npm-cache"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.4.2",
      "pluginSdkVersion": "2026.4.2"
    }
  }
}
